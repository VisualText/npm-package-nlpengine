{
  "name": "nlpplus",
  "version": "1.0.4",
  "description": "Node.js bindings for the NLP++ text-analysis engine (peer of the Python package NLPPlus)",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install": "node scripts/install.js",
    "build": "cmake-js compile",
    "build:debug": "cmake-js compile --debug",
    "rebuild": "cmake-js rebuild",
    "test": "node test/engine.test.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib/*.js",
    "src/",
    "scripts/",
    "CMakeLists.txt",
    "vcpkg.json",
    "analyzers/",
    "data/",
    "nlp-engine/",
    "prebuilds/"
  ],
  "keywords": [
    "nlp",
    "nlp++",
    "text",
    "text-analysis",
    "parser",
    "rule-based",
    "visualtext",
    "native",
    "node-addon"
  ],
  "author": "David De Hilster <contact@visualtext.org>",
  "license": "MIT",
  "homepage": "https://visualtext.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VisualText/npm-package-nlpengine.git"
  },
  "bugs": {
    "url": "https://github.com/VisualText/npm-package-nlpengine/issues"
  },
  "dependencies": {
    "cmake-js": "^7.3.0",
    "node-addon-api": "^8.0.0",
    "tar": "^7.4.0"
  },
  "binary": {
    "napi_versions": [
      8
    ]
  }
}
